# GitHub Secret Scanner Pro - 配置示例
# 复制此文件为 .env 并填入真实的配置信息

# ============================================================================
#                              代理配置（可选）
# ============================================================================
# 如果需要通过代理访问 GitHub API �?AI 服务 API，请设置此项
# 留空表示直连
# PROXY_URL=http://127.0.0.1:7890
PROXY_URL=

# ============================================================================
#                           GitHub Token 配置
# ============================================================================
# 使用逗号分隔�?GITHUB_TOKENS 环境变量
# 示例: GITHUB_TOKENS=ghp_xxx,ghp_yyy,ghp_zzz
GITHUB_TOKENS=

# ============================================================================
#                              扫描源开�?
# ============================================================================
ENABLE_ALL_SOURCES=false
ENABLE_GIST=true
ENABLE_GITLAB=true
ENABLE_PASTEBIN=false
ENABLE_SEARCHCODE=false
ENABLE_REALTIME=false
ENABLE_SOURCEGRAPH=true

# Enable Git partial clone based scanning (events/new repos/deleted repos)
ENABLE_GIT_CLONE=true

# Clone workspace inside container. Keep it under /app/output for persistence/debugging.
GIT_CLONE_DIR=/app/output/git_clone_cache

# ============================================================================
#                              运行选项
# ============================================================================
LOG_LEVEL=INFO
ENABLED_PROVIDERS=openai,deepseek,glm,minimax,kimi
MAX_SEARCH_RESULTS_PER_KEYWORD=100
DISABLE_MONITOR=false
DISABLE_CACHE=false
PANEL_USERNAME=admin
PANEL_PASSWORD=change-me-now
